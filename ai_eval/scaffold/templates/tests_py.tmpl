from __future__ import annotations

import subprocess
import sys

import pytest


@pytest.mark.ai_eval
def test_ai_eval_run() -> None:
    """Run the full eval suite. Exit 3 from `ai-evals run --fail-on-regression`
    surfaces as a pytest failure."""
    result = subprocess.run(
        [sys.executable, "-m", "ai_eval", "run", "--fail-on-regression"],
        check=False,
    )
    assert result.returncode == 0, (
        f"ai-evals run exited with {result.returncode} "
        "(0 = pass, 3 = regression / threshold breach)"
    )
